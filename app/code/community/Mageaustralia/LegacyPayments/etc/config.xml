<?xml version="1.0"?>
<!--
    Mageaustralia_LegacyPayments
    Rewrites Mage_Payment_Helper_Data::getMethodInstance() so that any payment
    code with no registered model resolves to a lightweight Stub instance
    instead of throwing "Unknown payment method".

    No payment codes are pre-registered here. The helper rewrite handles every
    unknown code dynamically; friendly titles for well-known historical codes
    live in Model/Stub.php (LEGACY_TITLES map).

    Stubs are NEVER selectable at checkout - the Stub model returns
    isAvailable=false and all _can* flags are false.
-->
<config>
    <modules>
        <Mageaustralia_LegacyPayments>
            <version>1.0.0</version>
        </Mageaustralia_LegacyPayments>
    </modules>
    <global>
        <models>
            <mageaustralia_legacypayments>
                <class>Mageaustralia_LegacyPayments_Model</class>
            </mageaustralia_legacypayments>
        </models>
        <helpers>
            <mageaustralia_legacypayments>
                <class>Mageaustralia_LegacyPayments_Helper</class>
            </mageaustralia_legacypayments>
            <payment>
                <rewrite>
                    <data>Mageaustralia_LegacyPayments_Helper_PaymentRewrite</data>
                </rewrite>
            </payment>
        </helpers>
    </global>
</config>
